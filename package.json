{
  "name": "smarttheft-browser-tests",
  "private": true,
  "version": "1.0.0",
  "description": "Playwright browser smoke tests for the SmartTheft portal",
  "scripts": {
    "deploy:check": "powershell -ExecutionPolicy Bypass -File deploy-check.ps1",
    "test:all": "powershell -ExecutionPolicy Bypass -File run-all-tests.ps1",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0"
  }
}
